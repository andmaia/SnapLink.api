<!-- Views/Error/Index.cshtml -->
@{
    ViewBag.Title = "Erro";
    Layout = "_Layout";
}

<div style="text-align:center; padding: 4rem 1rem;">
    <h1>Ops! Algo deu errado</h1>
    <p style="color: #666; font-size: 1.1rem;">@ViewBag.Message</p>
    <a href="/" style="display:inline-block; margin-top:1.5rem; padding: .6rem 1.4rem;
        background:#0066cc; color:#fff; border-radius:6px; text-decoration:none;">
        Voltar ao início
    </a>
</div>